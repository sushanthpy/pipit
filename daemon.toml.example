# Pipit Daemon Configuration
# Place this at daemon.toml, .pipit/daemon.toml, or ~/.config/pipit/daemon.toml

[server]
bind = "127.0.0.1"
port = 3100

[daemon]
drain_timeout_secs = 30
max_concurrent = 2
max_queue_depth = 20
# pid_path = "~/.pipit/pipitd.pid"
# store_path = "~/.pipit/daemon.db"

# ---------------------------------------------------------------------------
# Authentication — bearer tokens for the HTTP API
# If no tokens configured, all requests are allowed (dev mode).
# ---------------------------------------------------------------------------
[auth.tokens.admin]
secret = "${PIPIT_ADMIN_TOKEN:-changeme}"
permissions = ["submit", "status", "cancel", "steer"]

[auth.tokens.ci]
secret = "${PIPIT_CI_TOKEN}"
permissions = ["submit", "status"]

# ---------------------------------------------------------------------------
# Projects — each project has its own agent with independent config
# ---------------------------------------------------------------------------
[projects.myapp]
root = "/path/to/myapp"
provider = "anthropic"
model = "claude-sonnet-4-20250514"
mode = "balanced"
auto_commit = true
branch_prefix = "pipit/"
max_turns = 100
protected_paths = [".env", "*.pem", "secrets/**"]
# test_command = "cargo test"
# lint_command = "cargo clippy"
# allowed_tools = ["read_file", "edit_file", "grep", "glob", "bash"]

# [projects.frontend]
# root = "/path/to/frontend"
